# ============================================================
# BASKET GRID ENGINE — .env CONFIGURATION (MAINNET)
# ============================================================
# Copy this file to `.env` (no extension) in the same folder.
# NEVER commit .env to git.
#
# ⚠️ THIS BOT TRADES WITH REAL MONEY ON MAINNET. ⚠️
# Start with TINY basket sizes until you've verified behavior.
# ============================================================


# ============================================================
# DERIBIT (mainnet: https://www.deribit.com)
# ============================================================
# 1. Sign in at https://www.deribit.com
# 2. Account -> API
# 3. Create a new API key with "trade" + "read" scope
# 4. (Recommended) Restrict the key by IP address
# 5. Copy the Client ID and Client Secret below.
# ============================================================
DERIBIT_CLIENT_ID=
DERIBIT_CLIENT_SECRET=


# ============================================================
# HYPERLIQUID (mainnet: https://app.hyperliquid.xyz)
# ============================================================
# Hyperliquid uses EIP-712 signing with an ETHEREUM PRIVATE KEY.
#
# 🚫 DO NOT USE YOUR MAIN WALLET'S PRIVATE KEY.
# ✅ Create a dedicated "API Wallet" sub-key instead:
#
# 1. Go to https://app.hyperliquid.xyz/API
# 2. Connect your main wallet (the one holding the USDC)
# 3. Click "Generate" under API Wallets
# 4. Click "Approve" to authorize it (signs a transaction)
# 5. Copy the generated PRIVATE KEY below.
#
# The API wallet can ONLY trade — it cannot withdraw funds.
# Anyone with this key can still lose your money via bad trades.
# ============================================================
HYPERLIQUID_PRIVATE_KEY=

# Your main wallet address (the one holding the USDC).
# The API wallet trades ON BEHALF of this address.
HYPERLIQUID_MAIN_WALLET=


# ============================================================
# LOGGING
# ============================================================
RUST_LOG=info
